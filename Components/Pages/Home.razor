@page "/"
@inject HttpClient Http

<PageTitle>Farm selection</PageTitle>

<h1>Choose a farm</h1>

@if (errorMessage != null)
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (farms == null)
{
    <p><em>Loading farms...</em></p>
}
else if (!farms.Any())
{
    <p>No farms were found.</p>
}
else
{
    <p>Select a farm from the list below to view its sensors.</p>
    <div style="max-width: 400px">
        <ul class="list-group">
            @foreach (var farm in farms)
            {
                <li class="list-group-item">
                    <a href="@($"/{farm.Name}")">@farm.Name</a>
                </li>
            }
        </ul>
    </div>
}

@code {
    private List<FarmDTO>? farms;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            farms = await Http.GetFromJsonAsync<List<FarmDTO>>("farms");
        }
        catch (Exception ex)
        {
            errorMessage = "Unable to load farms. " + ex.Message;
        }
    }
}
