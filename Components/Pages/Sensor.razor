@page "/{farmName}/sensor"
@inject HttpClient Http
@inject NavigationManager NavigationManager
@using BlazorTemps.Models
@rendermode InteractiveServer 

<PageTitle>Sensor - @sensorName</PageTitle>

@if (isLoading)
{
    <p><em>Loading sensor data...</em></p>
}
else if (errorMessage != null)
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (currentSensor == null)
{
    <div class="alert alert-warning">Sensor not found.</div>
}
else
{
    <div class="sensor-detail-header">
        <div class="header-left">
            <div class="header-title">
                <div class="sensor-title-with-action">
                    <h1>@currentSensor.Name</h1>
                    <button class="edit-icon-button" type="button" @onclick="OpenEditModal" title="Edit sensor">✏️</button>
                </div>
                <p class="sensor-detail-farm">Farm: @farmName</p>
            </div>
            <div class="sensor-detail-card">
                <div class="sensor-detail-card-item">
                    <div class="card-item-label">Status</div>
                    <span class="@GetBadgeClass(sensorState)">@GetStatusLabel(sensorState)</span>
                </div>

                <div class="sensor-detail-card-item">
                    <div>
                        <span class="@GetTemperatureClass(sensorState, isOutOfRange)">
                            <b>@(FormatTemperature(currentSensor.LastTempF + currentSensor.CalibrationValueF))</b>
                        </span>
                        <span style="text-wrap: nowrap" class="card-item-subtext">at @(TimeHelpers.FormatTimestamp(currentSensor.LastTimeStamp))</span>
                    </div>
                </div>


                @if (currentSensor.MinTempF.HasValue)
                {
                    <div class="sensor-detail-card-item">
                        <div class="card-item-label" style="text-wrap: nowrap" >Min Temp</div>
                        <span 
                            class="metric-value @(sensorState == SensorAlertState.Offline ? "stale" : string.Empty)"
                        >
                            @FormatTemperature(currentSensor.MinTempF)
                        </span>
                    </div>
                }

                @if (currentSensor.MaxTempF.HasValue)
                {
                    <div class="sensor-detail-card-item">
                        <div class="card-item-label" style="text-wrap: nowrap" >Max Temp</div>
                        <span 
                            class="metric-value @(sensorState == SensorAlertState.Offline ? "stale" : string.Empty)"
                        >
                            @FormatTemperature(currentSensor.MaxTempF)
                        </span>
                    </div>
                }

                <div class="sensor-detail-card-item">
                    <span 
                        style="text-wrap: nowrap" 
                        class="metric-value @(sensorState == SensorAlertState.Offline ? "stale" : string.Empty)"
                    >
                        @TimeHelpers.FormatTimestamp(currentSensor.LastHeartbeat)
                    </span>
                </div>
            </div>
        </div>
        <a class="btn btn-secondary" href="/@farmName">Back to @farmName</a>
    </div>

    @if (!string.IsNullOrWhiteSpace(editSuccessMessage))
    {
        <div class="alert alert-success">@editSuccessMessage</div>
    }

    @if (isEditModalOpen)
    {
        <div class="modal-backdrop" @onclick="CloseEditModal">
            <div class="modal-card" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <div>
                        <h2>Edit sensor</h2>
                        <p class="modal-subtitle">Update sensor settings and authenticate with your farm password.</p>
                    </div>
                    <button class="modal-close-button" type="button" @onclick="CloseEditModal">✕</button>
                </div>

                @if (!string.IsNullOrWhiteSpace(editErrorMessage))
                {
                    <div class="alert alert-danger">@editErrorMessage</div>
                }

                <div class="form-field">
                    <label for="sensorName">Name</label>
                    <input id="sensorName" class="form-control" value="@editName" @oninput="e => editName = e.Value?.ToString() ?? string.Empty" />
                </div>
                <div class="form-field">
                    <label for="minTempF">Min Temp (°F)</label>
                    <input id="minTempF" type="number" step="0.1" class="form-control" value="@editMinTempF" @oninput="e => editMinTempF = ParseNullableDouble(e.Value?.ToString())" />
                </div>
                <div class="form-field">
                    <label for="maxTempF">Max Temp (°F)</label>
                    <input id="maxTempF" type="number" step="0.1" class="form-control" value="@editMaxTempF" @oninput="e => editMaxTempF = ParseNullableDouble(e.Value?.ToString())" />
                </div>
                <div class="form-field">
                    <label for="calibrationValueF">Calibration Temp (°F)</label>
                    <input id="calibrationValueF" type="number" step="0.1" class="form-control" value="@editCalibrationValueF" @oninput="e => editCalibrationValueF = ParseDouble(e.Value?.ToString())" />
                </div>
                <div class="form-field">
                    <label for="password">Password</label>
                    <input id="password" type="password" class="form-control" value="@editPassword" @oninput="e => editPassword = e.Value?.ToString() ?? string.Empty" />
                </div>

                <div class="modal-actions">
                    <button class="btn btn-secondary" type="button" @onclick="CloseEditModal" disabled="@isProcessingEdit">Cancel</button>
                    <button class="btn btn-primary" type="button" @onclick="SubmitSensorUpdateAsync" disabled="@isProcessingEdit">
                        @(isProcessingEdit ? "Saving..." : "Save changes")
                    </button>
                </div>
            </div>
        </div>
    }

    <div class="sensor-detail-container @(isLoadingReadings ? "loading" : "")">
        <div class="readings-stats-container">
            @if (isLoadingReadings)
            {
                <div class="loading-overlay">
                    <div class="spinner-container">
                        <div class="spinner"></div>
                        <p>Loading readings...</p>
                    </div>
                </div>
            }
            <div style="display: flex; gap: 10px; flex-wrap: wrap; align-items: flex-end;">
                <div class="time-range-selector">
                    <label for="timeRange">Time Range:</label>
                    <select id="timeRange" class="form-select" 
                        value="@selectedTimeRange" 
                        @onchange="@(async (ChangeEventArgs e) => { selectedTimeRange = e.Value?.ToString() ?? selectedTimeRange; await LoadReadings(); })"
                    >
                        <option value="Last Hour">Last Hour</option>
                        <option value="Last 6">Last 6 hours</option>
                        <option value="Last 12">Last 12 hours</option>
                        <option value="Last 24">Last 24 hours</option>
                        <option value="Last 48">Last 48 hours</option>
                        <option value="Last 72">Last 72 hours</option>
                        <option value="Last Week">Last Week</option>
                        <option value="Last Month">Last Month</option>
                        <option value="Last Year">Last Year</option>
                        <option value="All Time">All Time</option>
                    </select>
                </div>

                @if (readings != null && readings.Any())
                {
                    <div class="statistics-grid">
                        <div class="stat-card">
                            <div class="stat-label">Average</div>
                            <div class="stat-value">
                                @FormatTemperature(readings.Average(r => r.TempF))
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-label">Minimum</div>
                            <div class="stat-value">
                                @FormatTemperature(readings.Min(r => r.TempF))
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-label">Maximum</div>
                            <div class="stat-value">
                                @FormatTemperature(readings.Max(r => r.TempF))
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-label">Readings</div>
                            <div class="stat-value">@readings.Count</div>
                        </div>
                    </div>
                }

                <div>
                    <button class="btn btn-outline-success" @onclick="ToggleOutsideTemperature" disabled="@(isLoadingReadings)">
                        @(showOutsideTemperature ? "hide outside temperature" : "show outside temperature")
                    </button>
                </div>

                </div>

                <div><b>@currentSensor.Name</b></div>

                @if (readingsError != null)
                {
                    <div class="alert alert-danger">@readingsError</div>
                }
                else if ((readings != null && readings.Any()) || (showOutsideTemperature && outsideReadings != null && outsideReadings.Any()))
                {
                    <div class="chart-panel">
                        <RadzenChart Style="height: 420px; width: 100%;" ShowLegend="false" Animate="true">
                            <RadzenLegend Visible="false" />
                            <RadzenCategoryAxis 
                                Step="@chartStep" 
                                FormatString="@chartCategoryFormatString"
                            />
                            <RadzenValueAxis Min="@chartMin" Max="@chartMax" />

                            @foreach (var segment in lineSegments)
                            {
                                <RadzenLineSeries Data="@segment"
                                                  CategoryProperty="TimeStamp"
                                                  ValueProperty="TempF"
                                                  Stroke="steelblue"
                                                  StrokeWidth="2">
                                    <TooltipTemplate Context="data">
                                        <div style="padding: 4px 8px;">
                                            <strong>Time:</strong> @TimeHelpers.FormatTimestamp(data.TimeStamp) <br />
                                            <strong>Temp:</strong> @data.TempF °F
                                        </div>
                                    </TooltipTemplate>
                                </RadzenLineSeries>
                            }

                            @foreach (var segment in outsideLineSegments)
                            {
                                <RadzenLineSeries Data="@segment"
                                                  CategoryProperty="TimeStamp"
                                                  ValueProperty="TempF"
                                                  Stroke="green"
                                                  StrokeWidth="2">
                                    <TooltipTemplate Context="data">
                                        <div style="padding: 4px 8px;">
                                            <strong>Time:</strong> @TimeHelpers.FormatTimestamp(data.TimeStamp)<br />
                                            <strong>Outside Temp:</strong> @data.TempF °F
                                        </div>
                                    </TooltipTemplate>
                                </RadzenLineSeries>
                            }

                            @if (showMinThresholdLine && minThresholdSeries is not null)
                            {
                                <RadzenLineSeries Data="@minThresholdSeries"
                                                  CategoryProperty="TimeStamp"
                                                  ValueProperty="TempF"
                                                  Stroke="lightblue"
                                                  StrokeWidth="1">
                                    <TooltipTemplate Context="data">
                                        <div style="padding: 4px 8px;">
                                            <strong>Temp:</strong> @data.TempF °F
                                        </div>
                                    </TooltipTemplate>
                                </RadzenLineSeries>
                            }

                            @if (showMaxThresholdLine && maxThresholdSeries is not null)
                            {
                                <RadzenLineSeries Data="@maxThresholdSeries"
                                                  CategoryProperty="TimeStamp"
                                                  ValueProperty="TempF"
                                                  Stroke="red"
                                                  StrokeWidth="1">
                                    <TooltipTemplate Context="data">
                                        <div style="padding: 4px 8px;">
                                            <strong>Temp:</strong> @data.TempF °F
                                        </div>
                                    </TooltipTemplate>
                                </RadzenLineSeries>
                            }
                        </RadzenChart>
                    </div>

                    <div class="chart-panel" style="margin-top: 1.5rem;">
                        <RadzenChart Style="height: 420px; width: 100%;" ShowLegend="false" Animate="true">
                            <RadzenLegend Visible="false" />
                            <RadzenCategoryAxis Step="@chartStep" FormatString="@chartCategoryFormatString">
                                <RadzenAxisTitle Text="Time" />
                            </RadzenCategoryAxis>
                            <RadzenValueAxis Min="@humidityChartMin" Max="@humidityChartMax">
                                <RadzenAxisTitle Text="Humidity (%)" />
                            </RadzenValueAxis>

                            @foreach (var segment in humidityLineSegments)
                            {
                                <RadzenLineSeries Data="@segment"
                                                  CategoryProperty="TimeStamp"
                                                  ValueProperty="Humidity"
                                                  Stroke="steelblue"
                                                  StrokeWidth="2">
                                    <TooltipTemplate Context="data">
                                        <div style="padding: 4px 8px;">
                                            <strong>Time:</strong> @data.TimeStamp.ToString("g") <br />
                                            <strong>Humidity:</strong> @data.Humidity %
                                        </div>
                                    </TooltipTemplate>
                                </RadzenLineSeries>
                            }

                            @foreach (var segment in outsideHumidityLineSegments)
                            {
                                <RadzenLineSeries Data="@segment"
                                                  CategoryProperty="TimeStamp"
                                                  ValueProperty="Humidity"
                                                  Stroke="green"
                                                  StrokeWidth="2">
                                    <TooltipTemplate Context="data">
                                        <div style="padding: 4px 8px;">
                                            <strong>Time:</strong> @data.TimeStamp.ToString("g") <br />
                                            <strong>Outside Humidity:</strong> @data.Humidity %
                                        </div>
                                    </TooltipTemplate>
                                </RadzenLineSeries>
                            }
                        </RadzenChart>
                    </div>
                }
            </div>
    </div>
}

@code {
    [Parameter]
    public string? farmName { get; set; }

    [SupplyParameterFromQuery]
    public int? sensorID { get; set; }

    private SensorDTO? currentSensor;
    private List<ReadingDTO>? readings;
    private List<ReadingDTO>? outsideReadings;
    private string? errorMessage;
    private string? readingsError;
    private string? sensorName;
    private bool isLoading = true;
    private bool isLoadingReadings = false;
    private bool isEditModalOpen = false;
    private bool isProcessingEdit = false;
    private string editName = string.Empty;
    private double? editMinTempF;
    private double? editMaxTempF;
    private double editCalibrationValueF;
    private string editPassword = string.Empty;
    private string? editErrorMessage;
    private string? editSuccessMessage;
    private int currentFarmID;
    private string selectedTimeRange = "Last 6";
    private bool showOutsideTemperature = false;
    private bool isOutOfRange = false;

    private enum SensorAlertState
    {
        Active,
        TempProbeDown,
        Offline
    }

    private SensorAlertState sensorState = SensorAlertState.Active;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        errorMessage = null;
        readings = null;
        currentSensor = null;

        if (string.IsNullOrWhiteSpace(farmName) || !sensorID.HasValue || sensorID.Value <= 0)
        {
            errorMessage = "Invalid farm or sensor ID.";
            isLoading = false;
            return;
        }

        try
        {
            var farms = await Http.GetFromJsonAsync<List<FarmDTO>>("farms");
            var farm = farms?.FirstOrDefault(f => string.Equals(f.Name, farmName, StringComparison.OrdinalIgnoreCase));

            if (farm == null)
            {
                NavigationManager.NavigateTo("/not-found", true);
                return;
            }

            currentFarmID = farm.FarmID;
            editSuccessMessage = null;
            editErrorMessage = null;

            var sensors = await Http.GetFromJsonAsync<List<SensorDTO>>($"sensors/{farm.FarmID}");
            currentSensor = sensors?.FirstOrDefault(s => s.SensorID == sensorID.Value);

            if (currentSensor == null)
            {
                errorMessage = "Sensor not found in this farm.";
                isLoading = false;
                return;
            }

            sensorName = currentSensor.Name;
            sensorState = GetSensorAlertState(currentSensor.LastHeartbeat, currentSensor.LastTimeStamp);
            isOutOfRange = IsOutOfRange(
                currentSensor.LastTempF + currentSensor.CalibrationValueF, 
                currentSensor.MinTempF, currentSensor.MaxTempF
            );

            // Load initial readings
            await LoadReadings();
        }
        catch (Exception ex)
        {
            errorMessage = "Unable to load sensor data. " + ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OpenEditModal()
    {
        if (currentSensor == null)
        {
            return;
        }

        editErrorMessage = null;
        editSuccessMessage = null;
        PopulateEditFields();
        isEditModalOpen = true;
    }

    private void CloseEditModal()
    {
        isEditModalOpen = false;
        editPassword = string.Empty;
        editErrorMessage = null;
    }

    private void PopulateEditFields()
    {
        if (currentSensor == null)
        {
            return;
        }

        editName = currentSensor.Name;
        editMinTempF = currentSensor.MinTempF;
        editMaxTempF = currentSensor.MaxTempF;
        editCalibrationValueF = currentSensor.CalibrationValueF;
        editPassword = string.Empty;
    }

    private async Task SubmitSensorUpdateAsync()
    {
        if (currentSensor == null)
        {
            return;
        }

        isProcessingEdit = true;
        editErrorMessage = null;

        try
        {
            var bearerToken = await GetBearerTokenAsync();

            var updateDto = new SensorUpdateDTO
            {
                SensorID = currentSensor.SensorID,
                Name = editName,
                CalibrationValueF = editCalibrationValueF,
                MinTempF = editMinTempF,
                MaxTempF = editMaxTempF
            };

            using var request = new HttpRequestMessage(HttpMethod.Post, $"update-sensor/{currentSensor.SensorID}");
            request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", bearerToken);
            request.Content = JsonContent.Create(updateDto);

            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                var body = await response.Content.ReadAsStringAsync();
                editErrorMessage = $"Unable to update sensor: {response.ReasonPhrase}. {body}";
                return;
            }

            currentSensor.Name = editName;
            currentSensor.MinTempF = editMinTempF;
            currentSensor.MaxTempF = editMaxTempF;
            currentSensor.CalibrationValueF = editCalibrationValueF;
            sensorName = currentSensor.Name;
            editSuccessMessage = "Sensor updated successfully.";
            isEditModalOpen = false;
        }
        catch (Exception ex)
        {
            editErrorMessage = ex.Message;
        }
        finally
        {
            isProcessingEdit = false;
        }
    }

    private async Task<string> GetBearerTokenAsync()
    {
        var loginDto = new FarmLoginDTO
        {
            FarmID = currentFarmID,
            Name = farmName ?? string.Empty,
            Password = editPassword
        };

        using var response = await Http.PostAsJsonAsync("token", loginDto);
        if (!response.IsSuccessStatusCode)
        {
            var body = await response.Content.ReadAsStringAsync();
            throw new InvalidOperationException($"Unable to request token: {response.ReasonPhrase}. {body}");
        }

        var rawBody = await response.Content.ReadAsStringAsync();
        if (string.IsNullOrWhiteSpace(rawBody))
        {
            throw new InvalidOperationException("Token endpoint returned an empty response.");
        }

        try
        {
            var tokenResponse = System.Text.Json.JsonSerializer.Deserialize<TokenResponseDTO>(rawBody, new System.Text.Json.JsonSerializerOptions
            {
                PropertyNameCaseInsensitive = true
            });

            if (!string.IsNullOrWhiteSpace(tokenResponse?.Token))
            {
                return tokenResponse.Token;
            }

            if (!string.IsNullOrWhiteSpace(tokenResponse?.AccessToken))
            {
                return tokenResponse.AccessToken;
            }
        }
        catch
        {
            // Fall back to raw string
        }

        var trimmed = rawBody.Trim().Trim('"');
        if (!string.IsNullOrWhiteSpace(trimmed))
        {
            return trimmed;
        }

        throw new InvalidOperationException("Token response did not contain a valid token.");
    }

    private static double? ParseNullableDouble(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        return double.TryParse(value, out var parsed) ? parsed : null;
    }

    private static double ParseDouble(string? value)
    {
        return double.TryParse(value, out var parsed) ? parsed : 0.0;
    }

    private async Task LoadReadings()
    {
        if (!sensorID.HasValue)
        {
            return;
        }

        isLoadingReadings = true;
        readingsError = null;

        try
        {
            await LoadCurrentSensorReadings();

            if (showOutsideTemperature)
            {
                await LoadOutsideSensorReadings();
            }
            else
            {
                outsideReadings = null;
            }

            PrepareChartData();
        }
        catch (Exception ex)
        {
            readingsError = $"Unable to load readings: {ex.Message}";
            readings = new List<ReadingDTO>();
            outsideReadings = null;
            PrepareChartData();
        }
        finally
        {
            isLoadingReadings = false;
        }
    }

    private async Task LoadCurrentSensorReadings()
    {
        var encodedTimeRange = Uri.EscapeDataString(selectedTimeRange);
        var response = await Http.GetFromJsonAsync<ReadingsResponseDTO>(
            $"http://temperatures.chickenkiller.com/api/v1/sensor/{sensorID}?timeRange={encodedTimeRange}"
        );

        var fetched = response?.Readings ?? new List<ReadingDTO>();
        readings = FilterFutureReadings(fetched)
            .ToList();
        readings.ForEach(r => r.TempF += currentSensor?.CalibrationValueF ?? 0.0);
    }

    private async Task LoadOutsideSensorReadings()
    {
        if (sensorID == 35)
        {
            outsideReadings = readings?.ToList();
            return;
        }

        var encodedTimeRange = Uri.EscapeDataString(selectedTimeRange);
        var response = await Http.GetFromJsonAsync<ReadingsResponseDTO>(
            $"http://temperatures.chickenkiller.com/api/v1/sensor/35?timeRange={encodedTimeRange}"
        );

        var fetched = response?.Readings ?? new List<ReadingDTO>();
        outsideReadings = FilterFutureReadings(fetched).ToList();
    }

    private static IEnumerable<ReadingDTO> FilterFutureReadings(IEnumerable<ReadingDTO> readings)
    {
        var maxAllowedUtc = DateTime.UtcNow.AddMinutes(10);
        return readings.Where(r =>
        {
            var tsUtc = r.TimeStamp.Kind == DateTimeKind.Utc ? r.TimeStamp : DateTime.SpecifyKind(r.TimeStamp, DateTimeKind.Utc);
            return tsUtc <= maxAllowedUtc;
        });
    }

    private async Task ToggleOutsideTemperature()
    {
        showOutsideTemperature = !showOutsideTemperature;
        await LoadReadings();
    }

    private static string FormatTemperature(double? temperature)
    {
        return temperature.HasValue ? $"{temperature.Value:F1} °F" : "N/A";
    }


    private List<List<ReadingDTO>> lineSegments = new();
    private List<List<ReadingDTO>> outsideLineSegments = new();
    private List<List<ReadingDTO>> humidityLineSegments = new();
    private List<List<ReadingDTO>> outsideHumidityLineSegments = new();
    private List<ReadingDTO>? minThresholdSeries;
    private List<ReadingDTO>? maxThresholdSeries;
    private bool showMinThresholdLine;
    private bool showMaxThresholdLine;
    private double? chartMin;
    private double? chartMax;
    private double? humidityChartMin;
    private double? humidityChartMax;
    private TimeSpan chartStep = TimeSpan.FromHours(1);
    private string chartCategoryFormatString = "{0:MMM d h:mm tt}";

    private static bool IsOutOfRange(double? lastTemp, double? minTemp, double? maxTemp)
    {
        if (!lastTemp.HasValue)
        {
            return false;
        }

        if (minTemp.HasValue && lastTemp < minTemp)
        {
            return true;
        }

        if (maxTemp.HasValue && lastTemp > maxTemp)
        {
            return true;
        }

        return false;
    }

    private void PrepareChartData()
    {
        lineSegments.Clear();
        outsideLineSegments.Clear();
        minThresholdSeries = null;
        maxThresholdSeries = null;
        showMinThresholdLine = false;
        showMaxThresholdLine = false;
        chartMin = null;
        chartMax = null;

        // Define the Eastern Time Zone info
        TimeZoneInfo easternZone = TimeZoneInfo.FindSystemTimeZoneById("Eastern Standard Time");

        // Helper to map and convert a ReadingDTO list to Eastern Time
        List<ReadingDTO> ProcessReadingsToEastern(IEnumerable<ReadingDTO>? source)
        {
            return source?
                .OrderBy(r => r.TimeStamp)
                .Select(r => new ReadingDTO
                {
                    // Assuming all other fields map over, adjust if ReadingDTO has more properties
                    TimeStamp = TimeZoneInfo.ConvertTime(r.TimeStamp, easternZone),
                    TempF = r.TempF,
                    Humidity = r.Humidity
                })
                .ToList() ?? new List<ReadingDTO>();
        }

        if (readings.Any())
        {
            var minVal = readings.Min(r => r.TempF);
            var maxVal = readings.Max(r => r.TempF);
            var padding = Math.Max((maxVal - minVal) * 0.08, 1.0);
            chartMin = Math.Floor((minVal - padding) * 10) / 10.0;
            chartMax = Math.Ceiling((maxVal + padding) * 10) / 10.0;
        }

        var currentValues = new List<double>();
        var sortedReadings = ProcessReadingsToEastern(readings);
        if (sortedReadings.Any())
        {
            lineSegments.AddRange(BuildLineSegments(sortedReadings));
            humidityLineSegments.AddRange(BuildLineSegments(sortedReadings));
            currentValues.AddRange(sortedReadings.Select(r => r.TempF));
        }

        var sortedOutsideReadings = ProcessReadingsToEastern(outsideReadings);
        if (sortedOutsideReadings.Any())
        {
            outsideLineSegments.AddRange(BuildLineSegments(sortedOutsideReadings));
            outsideHumidityLineSegments.AddRange(BuildLineSegments(sortedOutsideReadings));
            currentValues.AddRange(sortedOutsideReadings.Select(r => r.TempF));

            var minVal = sortedOutsideReadings.Min(r => r.TempF);
            var maxVal = sortedOutsideReadings.Max(r => r.TempF);
            var padding = Math.Max((maxVal - minVal) * 0.08, 1.0);
            chartMin = Math.Min(chartMin ?? 1000, Math.Floor((minVal - padding) * 10) / 10.0);
            chartMax = Math.Max(chartMax ?? -1000, Math.Ceiling((maxVal + padding) * 10) / 10.0);
        }

        var humidityValues = new List<double>();
        if (sortedReadings.Any())
        {
            humidityValues.AddRange(sortedReadings.Select(r => r.Humidity));
        }

        if (sortedOutsideReadings.Any())
        {
            humidityValues.AddRange(sortedOutsideReadings.Select(r => r.Humidity));
        }

        if (!currentValues.Any())
        {
            return;
        }

        if (humidityValues.Any())
        {
            var minHumidity = humidityValues.Min();
            var maxHumidity = humidityValues.Max();
            var humidityPadding = Math.Max((maxHumidity - minHumidity) * 0.08, 1.0);
            humidityChartMin = Math.Floor((minHumidity - humidityPadding) * 10) / 10.0;
            humidityChartMax = Math.Ceiling((maxHumidity + humidityPadding) * 10) / 10.0;
        }
        else
        {
            humidityChartMin = null;
            humidityChartMax = null;
        }

        if (sortedReadings.Any() && 
            currentSensor?.MinTempF is double sensorMin &&
            sensorMin >= chartMin && sensorMin <= chartMax
        )
        {
            showMinThresholdLine = true;
            minThresholdSeries = sortedReadings.Select(r => new ReadingDTO
            {
                TimeStamp = r.TimeStamp,
                TempF = sensorMin
            }).ToList();
        }

        if (sortedReadings.Any() && 
            currentSensor?.MaxTempF is double sensorMax && 
            sensorMax >= chartMin && sensorMax <= chartMax
        )
        {
            showMaxThresholdLine = true;
            maxThresholdSeries = sortedReadings.Select(r => new ReadingDTO
            {
                TimeStamp = r.TimeStamp,
                TempF = sensorMax
            }).ToList();
        }

        var firstTimestamp = GetCombinedFirstTimestamp(sortedReadings, sortedOutsideReadings);
        var lastTimestamp = GetCombinedLastTimestamp(sortedReadings, sortedOutsideReadings);
        var rangeSpan = lastTimestamp - firstTimestamp;
        if (rangeSpan <= TimeSpan.Zero)
        {
            rangeSpan = TimeSpan.FromHours(1);
        }

        chartStep = GetChartStep(rangeSpan);
        chartCategoryFormatString = GetCategoryAxisFormat(rangeSpan);
    }

    private static IEnumerable<List<ReadingDTO>> BuildLineSegments(IReadOnlyList<ReadingDTO> readingsList)
    {
        var segments = new List<List<ReadingDTO>>();
        var currentSegment = new List<ReadingDTO>();
        DateTime? previousTimestamp = null;

        foreach (var reading in readingsList)
        {
            var readingTimestampUtc = reading.TimeStamp.Kind == DateTimeKind.Utc
                ? reading.TimeStamp
                : DateTime.SpecifyKind(reading.TimeStamp, DateTimeKind.Utc);

            if (previousTimestamp.HasValue && (readingTimestampUtc - previousTimestamp.Value).TotalHours > 1)
            {
                if (currentSegment.Count > 0)
                {
                    segments.Add(currentSegment);
                    currentSegment = new List<ReadingDTO>();
                }
            }

            currentSegment.Add(reading);
            previousTimestamp = readingTimestampUtc;
        }

        if (currentSegment.Count > 0)
        {
            segments.Add(currentSegment);
        }

        return segments;
    }

    private static DateTime GetCombinedFirstTimestamp(IReadOnlyList<ReadingDTO> current, IReadOnlyList<ReadingDTO> outside)
    {
        var timestamps = current.Select(r => GetUtcTimestamp(r.TimeStamp)).Concat(outside.Select(r => GetUtcTimestamp(r.TimeStamp))).ToList();
        return timestamps.Min();
    }

    private static DateTime GetCombinedLastTimestamp(IReadOnlyList<ReadingDTO> current, IReadOnlyList<ReadingDTO> outside)
    {
        var timestamps = current.Select(r => GetUtcTimestamp(r.TimeStamp)).Concat(outside.Select(r => GetUtcTimestamp(r.TimeStamp))).ToList();
        return timestamps.Max();
    }

    private static DateTime GetUtcTimestamp(DateTime timestamp)
    {
        return timestamp.Kind == DateTimeKind.Utc ? timestamp : DateTime.SpecifyKind(timestamp, DateTimeKind.Utc);
    }

    private static TimeSpan GetChartStep(TimeSpan rangeSpan)
    {
        return rangeSpan / 2;
        @* return rangeSpan switch
        {
            var span when span <= TimeSpan.FromHours(1) => TimeSpan.FromMinutes(10),
            var span when span <= TimeSpan.FromHours(6) => TimeSpan.FromHours(1),
            var span when span <= TimeSpan.FromHours(12) => TimeSpan.FromHours(2),
            var span when span <= TimeSpan.FromDays(1) => TimeSpan.FromHours(4),
            var span when span <= TimeSpan.FromDays(2) => TimeSpan.FromHours(6),
            var span when span <= TimeSpan.FromDays(3) => TimeSpan.FromHours(12),
            var span when span <= TimeSpan.FromDays(7) => TimeSpan.FromDays(1),
            var span when span <= TimeSpan.FromDays(14) => TimeSpan.FromDays(2),
            var span when span <= TimeSpan.FromDays(30) => TimeSpan.FromDays(4),
            var span when span <= TimeSpan.FromDays(90) => TimeSpan.FromDays(7),
            var span when span <= TimeSpan.FromDays(180) => TimeSpan.FromDays(14),
            _ => TimeSpan.FromDays(30),
        }; *@
    }

    private static string GetCategoryAxisFormat(TimeSpan rangeSpan)
    {
        return rangeSpan switch
        {
            var span when span <= TimeSpan.FromDays(1) => "{0:MMM d h:mm tt}",
            var span when span <= TimeSpan.FromDays(30) => "{0:MMM d}",
            var span when span <= TimeSpan.FromDays(365) => "{0:MMM yyyy}",
            _ => "{0:yyyy}",
        };
    }

    private static bool IsRecent(DateTime? timestamp)
    {
        if (!timestamp.HasValue)
        {
            return false;
        }

        return timestamp.Value >= DateTime.UtcNow.AddMinutes(-15);
    }

    private static SensorAlertState GetSensorAlertState(DateTime? lastHeartbeat, DateTime? lastTimeStamp)
    {
        var heartbeatRecent = IsRecent(lastHeartbeat);
        var readingRecent = IsRecent(lastTimeStamp);

        if (heartbeatRecent && readingRecent)
        {
            return SensorAlertState.Active;
        }

        if (heartbeatRecent && !readingRecent)
        {
            return SensorAlertState.TempProbeDown;
        }

        return SensorAlertState.Offline;
    }

    private static string GetHeartbeatText(DateTime? timestamp)
    {
        if (!timestamp.HasValue)
        {
            return "N/A";
        }

        // 1. Safely normalize the incoming timestamp to UTC
        var utcTime = timestamp.Value.Kind == DateTimeKind.Utc 
            ? timestamp.Value 
            : DateTime.SpecifyKind(timestamp.Value, DateTimeKind.Utc);

        // 2. Locate the US Eastern Time zone rule (handles EDT/EST shifts automatically)
        TimeZoneInfo easternZone = TimeZoneInfo.FindSystemTimeZoneById("Eastern Standard Time");
        
        // 3. Convert the normalized UTC time and get "Right Now" in Eastern Time
        DateTime easternTime = TimeZoneInfo.ConvertTimeFromUtc(utcTime, easternZone);
        DateTime easternToday = TimeZoneInfo.ConvertTimeFromUtc(DateTime.UtcNow, easternZone).Date;

        // 4. Compare dates using the identical timezone context
        if (easternTime.Date == easternToday)
        {
            return easternTime.ToString("t"); // e.g., "3:59 PM"
        }

        return easternTime.ToString("g"); // e.g., "7/10/2026 3:59 PM"
    }


    private static string GetStatusLabel(SensorAlertState state)
    {
        return state switch
        {
            SensorAlertState.TempProbeDown => "Temp probe down",
            SensorAlertState.Offline => "Offline",
            _ => "Active"
        };
    }

    private string GetBadgeClass(SensorAlertState state)
    {
        return state switch
        {
            SensorAlertState.TempProbeDown => "sensor-badge warning",
            SensorAlertState.Offline => "sensor-badge offline",
            _ => "sensor-badge active"
        };
    }

    private string GetTemperatureClass(SensorAlertState state, bool isOutOfRange)
    {
        return state switch
        {
            SensorAlertState.Offline => "sensor-last-temp stale",
            SensorAlertState.TempProbeDown => "sensor-last-temp stale",
            _ => isOutOfRange ? "sensor-last-temp out-of-range" : "sensor-last-temp"
        };
    }
