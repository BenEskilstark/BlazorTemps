@page "/{farmName}/sensor"
@inject HttpClient Http
@inject NavigationManager NavigationManager
@using BlazorTemps.Models
@rendermode InteractiveServer 

<PageTitle>Sensor - @sensorName</PageTitle>

@if (isLoading)
{
    <p><em>Loading sensor data...</em></p>
}
else if (errorMessage != null)
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (currentSensor == null)
{
    <div class="alert alert-warning">Sensor not found.</div>
}
else
{
    <div class="sensor-detail-header">
        <div class="header-left">
            <div class="header-title">
                <h1>@currentSensor.Name</h1>
                <p class="sensor-detail-farm">Farm: @farmName</p>
            </div>
            <div class="sensor-detail-card" style="max-height:80px">
                <div class="sensor-detail-card-item">
                    <div class="card-item-label">Status</div>
                    <span class="@GetBadgeClass(sensorState)">@GetStatusLabel(sensorState)</span>
                </div>

                <div class="sensor-detail-card-item">
                    <div>
                        <span class="@GetTemperatureClass(sensorState, isOutOfRange)"><b>@(FormatTemperature(currentSensor.LastTempF))</b></span>
                        <span style="text-wrap: nowrap" class="card-item-subtext">at @(FormatTimestamp(currentSensor.LastTimeStamp))</span>
                    </div>
                </div>

                <div class="sensor-detail-card-item">
                    <span 
                        style="text-wrap: nowrap" 
                        class="metric-value @(sensorState == SensorAlertState.Offline ? "stale" : string.Empty)"
                    >
                        @GetHeartbeatText(currentSensor.LastHeartbeat)
                    </span>
                </div>

                @if (currentSensor.MinTempF.HasValue)
                {
                    <div class="sensor-detail-card-item">
                        <div class="card-item-label" style="text-wrap: nowrap" >Min Temp</div>
                        <span 
                            class="metric-value @(sensorState == SensorAlertState.Offline ? "stale" : string.Empty)"
                        >
                            @FormatTemperature(currentSensor.MinTempF)
                        </span>
                    </div>
                }

                @if (currentSensor.MaxTempF.HasValue)
                {
                    <div class="sensor-detail-card-item">
                        <div class="card-item-label" style="text-wrap: nowrap" >Max Temp</div>
                        <span 
                            class="metric-value @(sensorState == SensorAlertState.Offline ? "stale" : string.Empty)"
                        >
                            @FormatTemperature(currentSensor.MaxTempF)
                        </span>
                    </div>
                }
            </div>
        </div>
        <a class="btn btn-secondary" href="/@farmName">Back to @farmName</a>
    </div>

    <div class="sensor-detail-container @(isLoadingReadings ? "loading" : "")">
        <div class="readings-stats-container">
            @if (isLoadingReadings)
            {
                <div class="loading-overlay">
                    <div class="spinner-container">
                        <div class="spinner"></div>
                        <p>Loading readings...</p>
                    </div>
                </div>
            }
            <div style="display: flex; gap: 10px;">
                <div class="time-range-selector">
                    <label for="timeRange">Time Range:</label>
                    <select id="timeRange" class="form-select" 
                        value="@selectedTimeRange" 
                        @onchange="@(async (ChangeEventArgs e) => { selectedTimeRange = e.Value?.ToString() ?? selectedTimeRange; await LoadReadings(); })"
                    >
                        <option value="Last Hour">Last Hour</option>
                        <option value="Last 6">Last 6 hours</option>
                        <option value="Last 12">Last 12 hours</option>
                        <option value="Last 24">Last 24 hours</option>
                        <option value="Last 48">Last 48 hours</option>
                        <option value="Last 72">Last 72 hours</option>
                        <option value="Last Week">Last Week</option>
                        <option value="Last Month">Last Month</option>
                        <option value="Last Year">Last Year</option>
                        <option value="All Time">All Time</option>
                    </select>
                </div>

                @if (readings != null && readings.Any())
                {
                    <div class="statistics-grid">
                        <div class="stat-card">
                            <div class="stat-label">Average</div>
                            <div class="stat-value">@FormatTemperature(readings.Average(r => r.TempF))</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-label">Minimum</div>
                            <div class="stat-value">@FormatTemperature(readings.Min(r => r.TempF))</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-label">Maximum</div>
                            <div class="stat-value">@FormatTemperature(readings.Max(r => r.TempF))</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-label">Readings</div>
                            <div class="stat-value">@readings.Count</div>
                        </div>
                    </div>
                }
                </div>

                @if (readingsError != null)
                {
                    <div class="alert alert-danger">@readingsError</div>
                }
                else if (readings != null && readings.Any())
                {
                    <div class="chart-panel">
                        <RadzenChart Style="height: 420px; width: 100%;" ShowLegend="false" Animate="true">
                            <RadzenLegend Visible="false" />
                            <RadzenCategoryAxis Step="@chartStep" FormatString="@chartCategoryFormatString">
                                <RadzenAxisTitle Text="Time" />
                            </RadzenCategoryAxis>
                            <RadzenValueAxis Min="@chartMin" Max="@chartMax">
                                <RadzenAxisTitle Text="Temperature (°F)" />
                            </RadzenValueAxis>

                            @foreach (var segment in lineSegments)
                            {
                                <RadzenLineSeries Data="@segment"
                                                  CategoryProperty="TimeStamp"
                                                  ValueProperty="TempF"
                                                  Stroke="steelblue"
                                                  StrokeWidth="2">
                                    <TooltipTemplate Context="data">
                                        <div style="padding: 4px 8px;">
                                            <strong>Time:</strong> @data.TimeStamp.ToString("g") <br />
                                            <strong>Temp:</strong> @data.TempF °F
                                        </div>
                                    </TooltipTemplate>
                                </RadzenLineSeries>
                            }

                            @if (showMinThresholdLine && minThresholdSeries is not null)
                            {
                                <RadzenLineSeries Data="@minThresholdSeries"
                                                  CategoryProperty="TimeStamp"
                                                  ValueProperty="TempF"
                                                  Stroke="lightblue"
                                                  StrokeWidth="1">
                                    <TooltipTemplate Context="data">
                                        <div style="padding: 4px 8px;">
                                            <strong>Temp:</strong> @data.TempF °F
                                        </div>
                                    </TooltipTemplate>
                                </RadzenLineSeries>
                            }

                            @if (showMaxThresholdLine && maxThresholdSeries is not null)
                            {
                                <RadzenLineSeries Data="@maxThresholdSeries"
                                                  CategoryProperty="TimeStamp"
                                                  ValueProperty="TempF"
                                                  Stroke="red"
                                                  StrokeWidth="1">
                                    <TooltipTemplate Context="data">
                                        <div style="padding: 4px 8px;">
                                            <strong>Temp:</strong> @data.TempF °F
                                        </div>
                                    </TooltipTemplate>
                                </RadzenLineSeries>
                            }
                        </RadzenChart>
                        
                    </div>
                }
            </div>
    </div>
}

@code {
    [Parameter]
    public string? farmName { get; set; }

    [SupplyParameterFromQuery]
    public int? sensorID { get; set; }

    private SensorDTO? currentSensor;
    private List<ReadingDTO>? readings;
    private string? errorMessage;
    private string? readingsError;
    private string? sensorName;
    private bool isLoading = true;
    private bool isLoadingReadings = false;
    private string selectedTimeRange = "Last 6";
    private bool isOutOfRange = false;

    private enum SensorAlertState
    {
        Active,
        TempProbeDown,
        Offline
    }

    private SensorAlertState sensorState = SensorAlertState.Active;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        errorMessage = null;
        readings = null;
        currentSensor = null;

        if (string.IsNullOrWhiteSpace(farmName) || !sensorID.HasValue || sensorID.Value <= 0)
        {
            errorMessage = "Invalid farm or sensor ID.";
            isLoading = false;
            return;
        }

        try
        {
            var farms = await Http.GetFromJsonAsync<List<FarmDTO>>("farms");
            var farm = farms?.FirstOrDefault(f => string.Equals(f.Name, farmName, StringComparison.OrdinalIgnoreCase));

            if (farm == null)
            {
                NavigationManager.NavigateTo("/not-found", true);
                return;
            }

            var sensors = await Http.GetFromJsonAsync<List<SensorDTO>>($"sensors/{farm.FarmID}");
            currentSensor = sensors?.FirstOrDefault(s => s.SensorID == sensorID.Value);

            if (currentSensor == null)
            {
                errorMessage = "Sensor not found in this farm.";
                isLoading = false;
                return;
            }

            sensorName = currentSensor.Name;
            sensorState = GetSensorAlertState(currentSensor.LastHeartbeat, currentSensor.LastTimeStamp);
            isOutOfRange = IsOutOfRange(currentSensor.LastTempF, currentSensor.MinTempF, currentSensor.MaxTempF);

            // Load initial readings
            await LoadReadings();
        }
        catch (Exception ex)
        {
            errorMessage = "Unable to load sensor data. " + ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadReadings()
    {
        if (!sensorID.HasValue)
        {
            return;
        }

        isLoadingReadings = true;
        readingsError = null;

            try
            {
                var encodedTimeRange = Uri.EscapeDataString(selectedTimeRange);
                var response = await Http.GetFromJsonAsync<ReadingsResponseDTO>(
                    $"http://temperatures.chickenkiller.com/api/v1/sensor/{sensorID}?timeRange={encodedTimeRange}"
                );

                var fetched = response?.Readings ?? new List<ReadingDTO>();

                // Filter out readings that are more than 10 minutes in the future
                var maxAllowedUtc = DateTime.UtcNow.AddMinutes(10);
                readings = fetched.Where(r =>
                {
                    var tsUtc = r.TimeStamp.Kind == DateTimeKind.Utc ? r.TimeStamp : DateTime.SpecifyKind(r.TimeStamp, DateTimeKind.Utc);
                    return tsUtc <= maxAllowedUtc;
                }).ToList();

                PrepareChartData();
            }
        catch (Exception ex)
        {
            readingsError = $"Unable to load readings: {ex.Message}";
            readings = new List<ReadingDTO>();
            PrepareChartData();
        }
        finally
        {
            isLoadingReadings = false;
        }
    }

    private static string FormatTemperature(double? temperature)
    {
        return temperature.HasValue ? $"{temperature.Value:F1} °F" : "N/A";
    }

    private static string FormatTimestamp(DateTime? timestamp)
    {
        if (!timestamp.HasValue)
        {
            return "N/A";
        }

        var utcTime = timestamp.Value.Kind == DateTimeKind.Utc ? timestamp.Value : DateTime.SpecifyKind(timestamp.Value, DateTimeKind.Utc);
        var localTime = utcTime.ToLocalTime();
        var today = DateTime.Now.Date;

        if (localTime.Date == today)
        {
            return localTime.ToString("t");
        }

        return localTime.ToString("g");
    }

    private List<List<ReadingDTO>> lineSegments = new();
    private List<ReadingDTO>? minThresholdSeries;
    private List<ReadingDTO>? maxThresholdSeries;
    private bool showMinThresholdLine;
    private bool showMaxThresholdLine;
    private double? chartMin;
    private double? chartMax;
    private TimeSpan chartStep = TimeSpan.FromHours(1);
    private string chartCategoryFormatString = "{0:MMM d h:mm tt}";

    private static bool IsOutOfRange(double? lastTemp, double? minTemp, double? maxTemp)
    {
        if (!lastTemp.HasValue)
        {
            return false;
        }

        if (minTemp.HasValue && lastTemp < minTemp)
        {
            return true;
        }

        if (maxTemp.HasValue && lastTemp > maxTemp)
        {
            return true;
        }

        return false;
    }

    private void PrepareChartData()
    {
        lineSegments.Clear();
        minThresholdSeries = null;
        maxThresholdSeries = null;
        showMinThresholdLine = false;
        showMaxThresholdLine = false;
        chartMin = null;
        chartMax = null;

        if (readings == null || !readings.Any())
        {
            return;
        }

        var sortedReadings = readings.OrderBy(r => r.TimeStamp).ToList();
        var currentSegment = new List<ReadingDTO>();
        DateTime? previousTimestamp = null;

        foreach (var reading in sortedReadings)
        {
            var readingTimestampUtc = reading.TimeStamp.Kind == DateTimeKind.Utc
                ? reading.TimeStamp
                : DateTime.SpecifyKind(reading.TimeStamp, DateTimeKind.Utc);

            if (previousTimestamp.HasValue && (readingTimestampUtc - previousTimestamp.Value).TotalHours > 1)
            {
                if (currentSegment.Count > 0)
                {
                    lineSegments.Add(currentSegment);
                    currentSegment = new List<ReadingDTO>();
                }
            }

            currentSegment.Add(reading);
            previousTimestamp = readingTimestampUtc;
        }

        if (currentSegment.Count > 0)
        {
            lineSegments.Add(currentSegment);
        }

        var values = sortedReadings.Select(r => r.TempF).ToList();
        var minValue = values.Min();
        var maxValue = values.Max();
        var padding = Math.Max((maxValue - minValue) * 0.08, 1.0);
        chartMin = Math.Floor((minValue - padding) * 10) / 10.0;
        chartMax = Math.Ceiling((maxValue + padding) * 10) / 10.0;

        if (currentSensor?.MinTempF is double sensorMin && sensorMin >= chartMin && sensorMin <= chartMax)
        {
            showMinThresholdLine = true;
            minThresholdSeries = sortedReadings.Select(r => new ReadingDTO
            {
                TimeStamp = r.TimeStamp,
                TempF = sensorMin
            }).ToList();
        }

        if (currentSensor?.MaxTempF is double sensorMax && sensorMax >= chartMin && sensorMax <= chartMax)
        {
            showMaxThresholdLine = true;
            maxThresholdSeries = sortedReadings.Select(r => new ReadingDTO
            {
                TimeStamp = r.TimeStamp,
                TempF = sensorMax
            }).ToList();
        }

        var firstTimestamp = GetUtcTimestamp(sortedReadings.First().TimeStamp);
        var lastTimestamp = GetUtcTimestamp(sortedReadings.Last().TimeStamp);
        var rangeSpan = lastTimestamp - firstTimestamp;
        if (rangeSpan <= TimeSpan.Zero)
        {
            rangeSpan = TimeSpan.FromHours(1);
        }

        chartStep = GetChartStep(rangeSpan);
        chartCategoryFormatString = GetCategoryAxisFormat(rangeSpan);
    }

    private static DateTime GetUtcTimestamp(DateTime timestamp)
    {
        return timestamp.Kind == DateTimeKind.Utc ? timestamp : DateTime.SpecifyKind(timestamp, DateTimeKind.Utc);
    }

    private static TimeSpan GetChartStep(TimeSpan rangeSpan)
    {
        return rangeSpan switch
        {
            var span when span <= TimeSpan.FromHours(1) => TimeSpan.FromMinutes(10),
            var span when span <= TimeSpan.FromHours(6) => TimeSpan.FromHours(1),
            var span when span <= TimeSpan.FromHours(12) => TimeSpan.FromHours(2),
            var span when span <= TimeSpan.FromDays(1) => TimeSpan.FromHours(4),
            var span when span <= TimeSpan.FromDays(2) => TimeSpan.FromHours(6),
            var span when span <= TimeSpan.FromDays(3) => TimeSpan.FromHours(12),
            var span when span <= TimeSpan.FromDays(7) => TimeSpan.FromDays(1),
            var span when span <= TimeSpan.FromDays(14) => TimeSpan.FromDays(2),
            var span when span <= TimeSpan.FromDays(30) => TimeSpan.FromDays(4),
            var span when span <= TimeSpan.FromDays(90) => TimeSpan.FromDays(7),
            var span when span <= TimeSpan.FromDays(180) => TimeSpan.FromDays(14),
            _ => TimeSpan.FromDays(30),
        };
    }

    private static string GetCategoryAxisFormat(TimeSpan rangeSpan)
    {
        return rangeSpan switch
        {
            var span when span <= TimeSpan.FromDays(1) => "{0:MMM d h:mm tt}",
            var span when span <= TimeSpan.FromDays(30) => "{0:MMM d}",
            var span when span <= TimeSpan.FromDays(365) => "{0:MMM yyyy}",
            _ => "{0:yyyy}",
        };
    }

    private static bool IsRecent(DateTime? timestamp)
    {
        if (!timestamp.HasValue)
        {
            return false;
        }

        return timestamp.Value >= DateTime.UtcNow.AddMinutes(-15);
    }

    private static SensorAlertState GetSensorAlertState(DateTime? lastHeartbeat, DateTime? lastTimeStamp)
    {
        var heartbeatRecent = IsRecent(lastHeartbeat);
        var readingRecent = IsRecent(lastTimeStamp);

        if (heartbeatRecent && readingRecent)
        {
            return SensorAlertState.Active;
        }

        if (heartbeatRecent && !readingRecent)
        {
            return SensorAlertState.TempProbeDown;
        }

        return SensorAlertState.Offline;
    }

    private static string GetHeartbeatText(DateTime? lastHeartbeat)
    {
        if (!lastHeartbeat.HasValue)
        {
            return "N/A";
        }

        var utcTime = lastHeartbeat.Value.Kind == DateTimeKind.Utc ? lastHeartbeat.Value : DateTime.SpecifyKind(lastHeartbeat.Value, DateTimeKind.Utc);
        var localTime = utcTime.ToLocalTime();
        var today = DateTime.Now.Date;

        if (localTime.Date == today)
        {
            return localTime.ToString("t");
        }

        return localTime.ToString("g");
    }

    private static string GetStatusLabel(SensorAlertState state)
    {
        return state switch
        {
            SensorAlertState.TempProbeDown => "Temp probe down",
            SensorAlertState.Offline => "Offline",
            _ => "Active"
        };
    }

    private string GetBadgeClass(SensorAlertState state)
    {
        return state switch
        {
            SensorAlertState.TempProbeDown => "sensor-badge warning",
            SensorAlertState.Offline => "sensor-badge offline",
            _ => "sensor-badge active"
        };
    }

    private string GetTemperatureClass(SensorAlertState state, bool isOutOfRange)
    {
        return state switch
        {
            SensorAlertState.Offline => "sensor-last-temp stale",
            SensorAlertState.TempProbeDown => "sensor-last-temp stale",
            _ => isOutOfRange ? "sensor-last-temp out-of-range" : "sensor-last-temp"
        };
    }
}
